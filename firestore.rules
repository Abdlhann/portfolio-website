rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read access to projects collection
    match /projects/{document} {
      allow read: if true;
      allow write: if true; // Allow all users to write (app has custom auth)
    }
    
    // Allow public read access to other collections if needed
    match /{document=**} {
      allow read: if true;
      allow write: if true; // Allow all users to write (app has custom auth)
    }
  }
}